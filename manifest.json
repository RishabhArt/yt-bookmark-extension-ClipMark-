{
  "manifest_version": 3,

  "name": "ClipMark - YouTube Smart Bookmarks",
  "version": "0.1.0",
  "description": "Save, organize, and manage YouTube timestamps with notes & AI",

  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://*.youtube.com/*"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["contentScript.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/bookmark.png",
        "assets/play.png",
        "assets/delete.png",
        "assets/save.png"
      ],
      "matches": ["https://*.youtube.com/*"]
    }
  ],

  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    },
    "default_title": "ClipMark",
    "default_popup": "popup.html"
  }
}